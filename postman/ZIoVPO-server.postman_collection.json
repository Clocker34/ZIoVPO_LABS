{
  "info": {
    "_postman_id": "ziovpo-server-collection",
    "name": "ZIoVPO Server",
    "description": "ЗИоВПО — локальная проверка API.\n\nРекомендуемый порядок в Collection Runner:\n1. Логин администратора → сохраняются accessToken / refreshToken\n2. Регистрация пользователя (держатель лицензии) → сохраняется userId\n3. Каталог продуктов/типов → productId и typeId\n4. Создание лицензии (админ)\n5. Активация на устройстве\n6. Проверка лицензии (тикет + ЭЦП)\n7. Продление\n\nПеред запуском: PostgreSQL (`docker compose up -d`), приложение (`cd adboard` → `mvnw spring-boot:run`). Для Docker задайте в окружении или `.env`: SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/adboard и SPRING_DATASOURCE_PASSWORD=adboard123.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8082" },
    { "key": "adminUsername", "value": "admin" },
    { "key": "adminPassword", "value": "ChangeMe1!" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "typeId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "licenseCode", "value": "" },
    { "key": "licenseId", "value": "" }
  ],
  "item": [
    {
      "name": "Сервис",
      "item": [
        {
          "name": "GET /info",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/info"
          }
        },
        {
          "name": "GET /hello",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/hello"
          }
        },
        {
          "name": "GET /api/ping (нужен JWT)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/ping"
          }
        }
      ]
    },
    {
      "name": "Аутентификация",
      "item": [
        {
          "name": "POST /auth/login (админ)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', j.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', j.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "POST /auth/refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', j.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', j.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "POST /api/auth/register (держатель лицензии)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('userId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"license_holder_demo\",\n  \"email\": \"license_holder_demo@example.local\",\n  \"password\": \"Secret1!x\",\n  \"name\": \"License Holder\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        }
      ]
    },
    {
      "name": "Лицензии",
      "item": [
        {
          "name": "GET /api/licenses/catalog",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    if (j.products && j.products.length) { pm.collectionVariables.set('productId', j.products[0].id); }",
                  "    if (j.types && j.types.length) { pm.collectionVariables.set('typeId', j.types[0].id); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/licenses/catalog"
          }
        },
        {
          "name": "GET /api/licenses/signing-public-key",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/licenses/signing-public-key"
          }
        },
        {
          "name": "POST /api/licenses/admin/create",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    pm.collectionVariables.set('licenseCode', j.licenseCode);",
                  "    pm.collectionVariables.set('licenseId', j.licenseId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"typeId\": \"{{typeId}}\",\n  \"userId\": {{userId}},\n  \"ownerId\": {{userId}},\n  \"deviceCount\": 2,\n  \"description\": \"Выдано из Postman\"\n}"
            },
            "url": "{{baseUrl}}/api/licenses/admin/create"
          }
        },
        {
          "name": "POST /api/licenses/activate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"licenseCode\": \"{{licenseCode}}\",\n  \"macAddress\": \"AA:BB:CC:DD:EE:01\",\n  \"deviceName\": \"postman-device\",\n  \"userId\": {{userId}}\n}"
            },
            "url": "{{baseUrl}}/api/licenses/activate"
          }
        },
        {
          "name": "POST /api/licenses/check",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"licenseCode\": \"{{licenseCode}}\",\n  \"macAddress\": \"AA:BB:CC:DD:EE:01\"\n}"
            },
            "url": "{{baseUrl}}/api/licenses/check"
          }
        },
        {
          "name": "POST /api/licenses/admin/renew",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"licenseId\": \"{{licenseId}}\",\n  \"extendDays\": 30\n}"
            },
            "url": "{{baseUrl}}/api/licenses/admin/renew"
          }
        }
      ]
    },
    {
      "name": "Администрирование пользователей",
      "item": [
        {
          "name": "GET /api/users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/users"
          }
        }
      ]
    }
  ]
}
