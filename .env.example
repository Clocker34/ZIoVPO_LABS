# Скопируйте в .env в корне репозитория. Файл .env не коммитьте с реальными паролями.

# Порт Spring Boot. Если 8081 занят уже запущенным adboard — поставьте 8082
SERVER_PORT=8081

# --- Подключение к PostgreSQL ---
# У тебя контейнер postgres на 5432:5432 — используй пароль из настроек контейнера:
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/adboard
SPRING_DATASOURCE_USERNAME=postgres
# Совпадает с POSTGRES_PASSWORD контейнера / локального Postgres; для IDE без .env см. дефолт в application.properties
SPRING_DATASOURCE_PASSWORD=adboard123

# --- Опционально: поднять второй Postgres из docker-compose этого репозитория (порт 5433 на хосте) ---
# Раскомментируй, если НЕ используешь свой контейнер на 5432:
# ADBOARD_SKIP_DOCKER_COMPOSE=0
# POSTGRES_HOST_PORT=5433
# POSTGRES_PASSWORD=adboard_local

# Если свой Postgres уже запущен — не вызывать docker compose из run-dev.ps1:
ADBOARD_SKIP_DOCKER_COMPOSE=1

# Первый администратор (один раз при пустой таблице users)
ADBOARD_BOOTSTRAP_ADMIN_USERNAME=admin
ADBOARD_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe1!

# --- JWT (access/refresh) — в проде задайте свой длинный секрет (≥32 символа) ---
# JWT_SECRET=
# JWT_ACCESS_MS=
# JWT_REFRESH_MS=

# --- ЭЦП тикетов лицензий (RSA PKCS#8 / X.509 SPKI, Base64 без PEM-заголовков) ---
# Соответствуют application.properties: license.signature.private-key-base64, license.signature.public-key-base64
# В GitHub: Settings → Secrets and variables → Actions → Variables (публичный ключ можно как Variable)
# GitLab CI/CD: Settings → CI/CD → Variables (MARKED: private key — Masked + Protected)
# LICENSE_SIGNATURE_PRIVATE_KEY_BASE64=
# LICENSE_SIGNATURE_PUBLIC_KEY_BASE64=

# --- Время жизни тикета проверки лицензии (секунды) ---
# LICENSE_TICKET_LIFETIME_SECONDS=300
